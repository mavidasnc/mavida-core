{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mavida-core/product-category-grid",
	"version": "1.8.0",
	"title": "Griglia categorie prodotto",
	"category": "woocommerce",
	"icon": "grid-view",
	"description": "Griglia delle categorie prodotto WooCommerce: nome in alto e immagine sotto, con colonne, esclusioni, aspetto card e call to action per card configurabili.",
	"keywords": [ "woocommerce", "categorie", "prodotti", "griglia" ],
	"textdomain": "mavida-core",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"columns": {
			"type": "number",
			"default": 4
		},
		"mobileColumns": {
			"type": "number",
			"default": 2
		},
		"excludedCategories": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"includedCategories": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"cacheMinutes": {
			"type": "number",
			"default": 60
		},
		"cardBackgroundColor": {
			"type": "string",
			"default": "#ffffff"
		},
		"cardBorderRadius": {
			"type": "number",
			"default": 12
		},
		"cardPadding": {
			"type": "number",
			"default": 16
		},
		"nameTagName": {
			"type": "string",
			"default": "span"
		},
		"nameColor": {
			"type": "string",
			"default": ""
		},
		"nameFontSize": {
			"type": "number",
			"default": 16
		},
		"ctaText": {
			"type": "string",
			"default": ""
		},
		"ctaIsButton": {
			"type": "boolean",
			"default": true
		},
		"ctaTextColor": {
			"type": "string",
			"default": ""
		},
		"ctaBackgroundColor": {
			"type": "string",
			"default": ""
		},
		"ctaFontSize": {
			"type": "number",
			"default": 16
		},
		"defaultImageId": {
			"type": "number",
			"default": 0
		},
		"customCss": {
			"type": "string",
			"default": ""
		},
		"cssInstanceId": {
			"type": "string",
			"default": ""
		}
	},
	"example": {
		"attributes": {
			"columns": 4
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
